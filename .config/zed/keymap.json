[
  // Markdown プレビュー（cmd-shift-v）で j/k 上下スクロール
  {
    "context": "MarkdownPreview",
    "bindings": {
      "j": "markdown::ScrollDown",
      "k": "markdown::ScrollUp"
    }
  }
]
