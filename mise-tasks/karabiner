#!/bin/bash
#MISE description="Build Karabiner config from karabiner.ts"
# No sources/outputs skip here: the build's sync step (`cmp -s || cp`) leaves
# karabiner.json's mtime untouched when content is unchanged, so mise's
# timestamp-based up-to-date check would never fire. The build itself takes
# only a few seconds and is idempotent.
set -euo pipefail

if ! command -v bun >/dev/null 2>&1; then
  echo "bun not found, skipping Karabiner build"
  exit 0
fi
cd .config/karabiner
bun install --frozen-lockfile
bun run build
